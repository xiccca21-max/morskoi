// Naval Clash — Prisma schema (SQLite для локальной разработки)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===========================================================
// Users
// ===========================================================
model User {
  id            String   @id @default(cuid())
  telegramId    String   @unique
  username      String?
  firstName     String?
  lastName      String?
  nickname      String?  // пользовательский ник (если задан вручную)
  avatar        String?
  language      String?  // language_code из Telegram

  balance       Float    @default(0)   // полный игровой баланс (реал + бонус)
  withdrawable  Float    @default(0)   // часть, которую можно вывести (реальные деньги)

  wins          Int      @default(0)
  losses        Int      @default(0)
  draws         Int      @default(0)
  totalWagered  Float    @default(0)
  totalWon      Float    @default(0)

  banned        Boolean  @default(false)

  // Согласие с правилами и возрастом (18+)
  agreedToTermsAt DateTime?

  // Реферальная система
  referredById  String?
  referralCount Int      @default(0)

  // Ответственная игра
  dailyDepositLimit Float?
  selfExcludedUntil DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  matchesAsP1   Match[]  @relation("Player1")
  matchesAsP2   Match[]  @relation("Player2")
  matchesWon    Match[]  @relation("Winner")

  transactions  Transaction[]
  queueEntry    MatchmakingQueue?
  lobbies       Lobby[]  @relation("LobbyHost")
  withdrawals   WithdrawalRequest[]
  referrer      User?    @relation("Referral", fields: [referredById], references: [id])
  referrals     User[]   @relation("Referral")

  @@index([telegramId])
  @@index([referredById])
}

// ===========================================================
// Match
// MatchStatus: PENDING | PLACEMENT | IN_PROGRESS | FINISHED | CANCELLED
// ===========================================================
model Match {
  id            String    @id @default(cuid())
  player1Id     String
  player2Id     String?
  winnerId      String?

  wagerAmount   Float
  rakeAmount    Float     @default(0)
  prizePool     Float

  status        String    @default("PENDING")

  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime  @default(now())

  player1       User      @relation("Player1", fields: [player1Id], references: [id])
  player2       User?     @relation("Player2", fields: [player2Id], references: [id])
  winner        User?     @relation("Winner",  fields: [winnerId],  references: [id])

  gameState     GameState?

  @@index([status])
  @@index([player1Id])
  @@index([player2Id])
  @@index([winnerId])
}

// ===========================================================
// GameState
// gameStatus: PLACEMENT | IN_PROGRESS | FINISHED
// ===========================================================
model GameState {
  id            String   @id @default(cuid())
  matchId       String   @unique
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  currentTurn   String?
  player1Board  String   // JSON
  player2Board  String   // JSON
  attackHistory String   @default("[]") // JSON
  gameStatus    String   @default("PLACEMENT")
  turnDeadline  DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ===========================================================
// Transactions
// type: DEPOSIT | WITHDRAW | WAGER_LOCK | WAGER_REFUND | PAYOUT | RAKE
// status: PENDING | COMPLETED | FAILED | REVERSED
// ===========================================================
model Transaction {
  id        String   @id @default(cuid())
  userId    String
  matchId   String?
  type      String
  amount    Float
  status    String   @default("COMPLETED")
  meta      String?  // JSON string

  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([matchId])
  @@index([type])
}

// ===========================================================
// Withdrawal requests
// status: PENDING | APPROVED | PAID | REJECTED
// method: CARD | TON | CRYPTO
// ===========================================================
model WithdrawalRequest {
  id          String   @id @default(cuid())
  userId      String
  amount      Float    // запрошенная сумма (брутто)
  fee         Float    @default(0)
  net         Float    // к выплате (amount - fee)
  method      String   // CARD | TON | CRYPTO
  destination String   // номер карты / адрес кошелька
  status      String   @default("PENDING")
  note        String?  // комментарий админа при отклонении
  createdAt   DateTime @default(now())
  processedAt DateTime?

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

// ===========================================================
// Action log (аудит важных действий)
// ===========================================================
model ActionLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // DEPOSIT | WITHDRAW_REQUEST | MATCH_CREATE | MATCH_JOIN | ...
  meta      String?  // JSON
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
}

// ===========================================================
// Matchmaking queue
// ===========================================================
model MatchmakingQueue {
  id          String   @id @default(cuid())
  userId      String   @unique
  wagerAmount Float
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([wagerAmount, createdAt])
}

// ===========================================================
// Private lobbies
// status: OPEN | STARTED | CLOSED
// ===========================================================
model Lobby {
  id          String   @id @default(cuid())
  code        String   @unique
  hostId      String
  wagerAmount Float
  status      String   @default("OPEN")
  isPublic    Boolean  @default(false)
  matchId     String?
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  host        User     @relation("LobbyHost", fields: [hostId], references: [id])

  @@index([code])
  @@index([status])
  @@index([isPublic, status])
}

# =========================
# Telegram
# =========================
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_BOT_USERNAME=NavalClashBot
TELEGRAM_WEBAPP_URL=https://yourdomain.com
# Опционально: публичный URL для webhook (Telegram → backend)
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/api/telegram/webhook

# =========================
# Auth
# =========================
JWT_SECRET=change_me_super_secret_32_chars_minimum
JWT_EXPIRES_IN=7d

# =========================
# Database
# =========================
POSTGRES_USER=naval
POSTGRES_PASSWORD=naval_pwd
POSTGRES_DB=naval_clash
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://naval:naval_pwd@postgres:5432/naval_clash?schema=public

# =========================
# Redis
# =========================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# =========================
# Backend
# =========================
NODE_ENV=development
BACKEND_PORT=4000
CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# =========================
# Game economy
# =========================
PLATFORM_RAKE_PERCENT=5
MIN_WAGER=1
MAX_WAGER=1000
PLACEMENT_TIMEOUT_SEC=30
TURN_TIMEOUT_SEC=20

# =========================
# Frontend (vite)
# =========================
VITE_API_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000
VITE_TG_BOT_USERNAME=NavalClashBot
